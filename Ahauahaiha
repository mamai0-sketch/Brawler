local function sendAIMessage(userMessage)
local currentTime = os.time()
local currentDate = os.date("*t").day
if currentDate ~= lastResetDate then messageCountToday = 0 lastResetDate = currentDate end
if messageCountToday >= MAX_MESSAGES_PER_DAY then addAIMessage("system","Daily message limit reached (" .. MAX_MESSAGES_PER_DAY .. ")") return end
if (currentTime - lastMessageTime) < RATE_LIMIT_DELAY then local remaining = RATE_LIMIT_DELAY - (currentTime - lastMessageTime) addAIMessage("system","Please wait " .. remaining .. " seconds") return end
if #userMessage > MAX_MESSAGE_LENGTH then addAIMessage("system","Message too long! Max " .. MAX_MESSAGE_LENGTH) return end
lastMessageTime = currentTime
messageCountToday = messageCountToday + 1
addAIMessage("user",userMessage)
