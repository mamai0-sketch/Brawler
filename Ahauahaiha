local function getRequestFunction() return syn and syn.request or http and http.request or request end
local function sendRequest(body)
local requestFn = getRequestFunction()
if not requestFn then return nil,"Executor not supported" end
local options = {Url = API_URL,Method = "POST",Headers = {["Content-Type"] = "application/json"},Body = HttpService:JSONEncode(body)}
if REQUEST_TIMEOUT then options.Timeout = REQUEST_TIMEOUT end
local success,resp = pcall(function() return requestFn(options) end)
if not success then return nil,"Request error: " .. tostring(resp) end
if resp.StatusCode ~= 200 then local errData pcall(function() errData = HttpService:JSONDecode(resp.Body) end) local errMsg = (errData and errData.error) or ("HTTP " .. tostring(resp.StatusCode)) return nil,errMsg end
local data local parseSuccess,parsed = pcall(function() return HttpService:JSONDecode(resp.Body) end) if not parseSuccess then return nil,"JSON parse error" end return parsed,nil
end
