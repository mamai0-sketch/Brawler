local function RefreshESP()
for _,plr in pairs(Players:GetPlayers()) do
if plr.Character then
if plr.Character:FindFirstChild("LeakedHighlight") then plr.Character.LeakedHighlight:Destroy() end
if plr.Character:FindFirstChild("LeakedTag") then plr.Character.LeakedTag:Destroy() end
end
end
if espEnabled then
for lower,logs in pairs(usersWithLogs) do
if logs and #logs > 0 then
local plr = Players:FindFirstChild(lower)
if plr and plr.Character and plr.Character:FindFirstChild("Head") then
local hl = Instance.new("Highlight")
