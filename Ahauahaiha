AIInputBox.FocusLost:Connect(function(enterPressed) if enterPressed and not UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and not UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then local message = AIInputBox.Text:gsub("^%s*(.-)%s*$","%1") if message ~= "" then sendAIMessage(message) AIInputBox.Text = "" end end end)
local autoScanToggle = createToggle("Auto Scan Players",0,function(state) autoScanEnabled = state end)
local espToggle = createToggle("ESP Highlight",60,function(state) espEnabled = state if state then RefreshESP() else for _,plr in pairs(Players:GetPlayers()) do if plr.Character then if plr.Character:FindFirstChild("LeakedHighlight") then plr.Character.LeakedHighlight:Destroy() end if plr.Character:FindFirstChild("LeakedTag") then plr.Character.LeakedTag:Destroy() end end end end end)
local antiAfkToggle = createToggle("Anti-AFK",120,function(state) antiAfkEnabled = state if state then local vu = game:GetService("VirtualUser") Player.Idled:Connect(function() if antiAfkEnabled then vu:Button2Down(Vector2.new(0,0),workspace.CurrentCamera.CFrame) task.wait(1) vu:Button2Up(Vector2.new(0,0),workspace.CurrentCamera.CFrame) end end) end end)
local musicToggle = createToggle("Music Player",180,function(state) musicEnabled = state if state then pcall(function() musicGuiRef = loadstring(game:HttpGet("https://raw.githubusercontent.com/wenshertt/Music/refs/heads/main/MuzikAcma.lua"))() end) else local spotifyPlayer = CoreGui:FindFirstChild("SpotifyPlayer") or PlayerGui:FindFirstChild("SpotifyPlayer") if spotifyPlayer then spotifyPlayer:Destroy() end for _,sound in pairs(workspace:GetDescendants()) do if sound:IsA("Sound") then sound:Stop() sound:Destroy() end end for _,sound in pairs(game:GetDescendants()) do if sound:IsA("Sound") and sound.Parent and not sound.Parent:IsA("Player") then sound:Stop() sound:Destroy() end end for _,conn in pairs(musicConnections) do pcall(function() conn:Disconnect() end) end musicConnections = {} musicGuiRef = nil end end)
CloseBtn.MouseButton1Click:Connect(function() if musicEnabled then local spotifyPlayer = CoreGui:FindFirstChild("SpotifyPlayer") or PlayerGui:FindFirstChild("SpotifyPlayer") if spotifyPlayer then spotifyPlayer:Destroy() end for _,sound in pairs(workspace:GetDescendants()) do if sound:IsA("Sound") then sound:Stop() sound:Destroy() end end for _,sound in pairs(game:GetDescendants()) do if sound:IsA("Sound") and sound.Parent and not sound.Parent:IsA("Player") then sound:Stop() sound:Destroy() end end end ScreenGui:Destroy() end)
local isMinimized = false
MinimizeBtn.MouseButton1Click:Connect(function()
if isMinimized then
MinimizedIcon.Visible = false
IconGlow.Visible = false
IconRing.Visible = false
LeftPanel.Visible = true
RightPanel.Visible = true
TopBar.Visible = true
ButtonFrame.Visible = true
ControlFrame.Visible = true
MainFrame.BackgroundTransparency = 0
MainFrame.BackgroundColor3 = Colors.Background
TweenService:Create(MainFrame,TweenInfo.new(0.5,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size = GUI_SIZE,Position = UDim2.new(0.5,-450,0.5,-300)}):Play()
isMinimized = false
else
LeftPanel.Visible = false
RightPanel.Visible = false
TopBar.Visible = false
ButtonFrame.Visible = false
ControlFrame.Visible = false
MainFrame.BackgroundTransparency = 1
MainFrame.BackgroundColor3 = Colors.Background
MinimizedIcon.Visible = true
IconGlow.Visible = true
IconRing.Visible = true
TweenService:Create(MainFrame,TweenInfo.new(0.5,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size = MINI_SIZE,Position = MINI_POSITION}):Play()
isMinimized = true
end
end)
MinimizedIcon.MouseButton1Click:Connect(function() if isMinimized then MinimizeBtn.MouseButton1Click:Fire() end end)
local dragToggle,dragStart,startPos
TopBar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragToggle = true dragStart = input.Position startPos = MainFrame.Position input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragToggle = false end) end end end)
UserInputService.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement and dragToggle then local delta = input.Position - dragStart MainFrame.Position = UDim2.new(startPos.X.Scale,startPos.X.Offset + delta.X,startPos.Y.Scale,startPos.Y.Offset + delta.Y) end end)
MainFrame.Size = UDim2.new(0,0,0,0)
MainFrame.Position = UDim2.new(0.5,-450,0.5,-300)
MainFrame.Visible = true
TweenService:Create(MainFrame,TweenInfo.new(0.7,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size = GUI_SIZE}):Play()
end
CheckWhitelistFirst()
