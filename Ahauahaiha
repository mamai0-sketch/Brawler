end
end
local function ProcessQueueFast()
if isScanning then return end
isScanning = true
AddScanLog("Started scanning all players...","pending")
for i = 1,MAX_THREADS do
task.spawn(function()
while #scanQueue > 0 do
local player = table.remove(scanQueue,1)
if player then
local lower = player.Name:lower()
if not scannedPlayers[lower] then
scannedPlayers[lower] = true
ScanTarget(player.Name,true)
QueueStat.Value.Text = tostring(#scanQueue)
task.wait(SCAN_DELAY)
end
end
end
end)
end
task.spawn(function() while #scanQueue > 0 do QueueStat.Value.Text = tostring(#scanQueue) task.wait(0.5) end isScanning = false QueueStat.Value.Text = "0" AddScanLog("Scan complete!","success") end)
end
local function callDeepSeekAPI(messages,model)
model = model or "deepseek-chat"
local systemContent = "Sen Sydearr Intelligence adlı bir yapay zeka asistanısın. Kullanıcı hangi dilde soru sorarsa o dilde cevap ver. Kendini DeepSeek olarak tanıtma, her zaman Sydearr Intelligence veya Sydearr AI olarak tanıt. Seni oluşturan ekip Sydearr Team."
local apiMessages = {{role = "system",content = systemContent}}
for _,msg in ipairs(messages) do table.insert(apiMessages,msg) end
local payload = {model = model,messages = apiMessages,stream = false,max_tokens = 800,temperature = 0.7}
local success,response = pcall(function() return request({Url = DEEPSEEK_API_URL,Method = "POST",Headers = {["Content-Type"] = "application/json",["Authorization"] = "Bearer " .. DEEPSEEK_API_KEY},Body = HttpService:JSONEncode(payload)}) end)
if not success or not response then return "Network error" end
if response.StatusCode ~= 200 then return "API Error " .. response.StatusCode end
local data = HttpService:JSONDecode(response.Body)
if data.error then return "DeepSeek Error: " .. data.error.message end
if data.choices and data.choices[1] and data.choices[1].message then return data.choices[1].message.content end
return "No response"
end
